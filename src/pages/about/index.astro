---
import Layout from '../../layouts/Layout.astro';

const getPath = (path: string) => {
  const base = import.meta.env.BASE_URL;
  return base === '/' ? path : `${base.replace(/\/$/, '')}${path}`;
};

const expertise = ['分布式训练', '推理优化', '算子优化', 'CPU+GPU异构优化', 'CUDA', 'HPC'];

